    {
      "id": "660e8400-e29b-41d4-a716-446655440400",
      "title": "Methodology",
      "level": 1,
      "description": "Detailed model methodology documentation",
      "blocks": [],
      "childrenSections": [
        {
          "id": "660e8400-e29b-41d4-a716-446655440410",
          "title": "Modeling Approach",
          "level": 2,
          "blocks": [
            {
              "id": "660e8400-e29b-41d4-a716-446655440411",
              "type": "USER_INPUT",
              "title": "Methodology Selection",
              "userFields": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440412",
                  "name": "model_technique",
                  "label": "Primary Modeling Technique",
                  "type": "SELECT",
                  "required": true,
                  "options": [
                    {"value": "logistic", "label": "Logistic Regression"},
                    {"value": "xgboost", "label": "XGBoost/Gradient Boosting"},
                    {"value": "random_forest", "label": "Random Forest"},
                    {"value": "neural_network", "label": "Neural Network"},
                    {"value": "linear", "label": "Linear Regression"},
                    {"value": "survival", "label": "Survival Analysis"},
                    {"value": "scorecard", "label": "Scorecard (WoE)"},
                    {"value": "ensemble", "label": "Ensemble Method"},
                    {"value": "other", "label": "Other"}
                  ]
                },
                {
                  "id": "660e8400-e29b-41d4-a716-446655440413",
                  "name": "target_definition",
                  "label": "Target Variable Definition",
                  "type": "TEXTAREA",
                  "required": true,
                  "placeholder": "e.g., 90+ days past due within 12 months of observation"
                }
              ],
              "regenerationPolicy": {"allowed": false, "maxAttempts": 1, "cacheKeyStrategy": "none"},
              "citationPolicy": {"requireCitations": false, "allowedSources": []}
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440414",
              "type": "LLM_TEXT",
              "title": "Methodology Description",
              "instructions": "Provide a detailed description of the modeling methodology. Include: (1) Theoretical basis and mathematical formulation, (2) Key assumptions, (3) Why this approach was chosen over alternatives, (4) Hyperparameters and their selection, (5) Cross-validation or holdout strategy, (6) Feature engineering techniques applied.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440415",
                  "type": "REPO",
                  "query": "model training fit hyperparameters",
                  "filters": {"filePatterns": ["*.py", "*.r", "*.ipynb"]}
                }
              ],
              "outputContract": {"schema": "LLM_TEXT"},
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": true, "allowedSources": ["repo", "artifact"]}
            }
          ],
          "childrenSections": []
        },
        {
          "id": "660e8400-e29b-41d4-a716-446655440420",
          "title": "Model Specification",
          "level": 2,
          "blocks": [
            {
              "id": "660e8400-e29b-41d4-a716-446655440421",
              "type": "LLM_TABLE",
              "title": "Model Coefficients/Weights",
              "instructions": "Document the final model specification. For regression models show coefficients, standard errors, p-values, and odds ratios. For tree-based models show feature importances. Include variable names and interpretations.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440422",
                  "type": "ARTIFACT",
                  "description": "Model output and coefficients"
                }
              ],
              "outputContract": {
                "schema": "LLM_TABLE",
                "tableColumns": [
                  {"key": "variable", "label": "Variable", "dataType": "string"},
                  {"key": "coefficient", "label": "Coefficient", "dataType": "number"},
                  {"key": "std_error", "label": "Std Error", "dataType": "number"},
                  {"key": "p_value", "label": "P-Value", "dataType": "number"},
                  {"key": "importance", "label": "Importance %", "dataType": "percentage"}
                ]
              },
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": true, "allowedSources": ["artifact"]}
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440423",
              "type": "LLM_CHART",
              "title": "Feature Importance Chart",
              "instructions": "Create a horizontal bar chart showing relative feature importance for all model variables. Order by importance descending.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440424",
                  "type": "ARTIFACT",
                  "description": "Feature importance data"
                }
              ],
              "outputContract": {
                "schema": "LLM_CHART",
                "chartConfig": {
                  "preferredType": "bar",
                  "xKey": "importance",
                  "yKeys": ["variable"]
                }
              },
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": true, "allowedSources": ["artifact"]}
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440425",
              "type": "LLM_TEXT",
              "title": "Model Equation/Scoring Logic",
              "instructions": "Document the complete model equation or scoring logic. For scorecards, include point allocations. For ML models, describe how the final score/probability is calculated. Include any post-processing or calibration adjustments.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440426",
                  "type": "REPO",
                  "query": "score prediction calculate probability",
                  "filters": {"filePatterns": ["*.py", "*.r"]}
                }
              ],
              "outputContract": {"schema": "LLM_TEXT"},
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": true, "allowedSources": ["repo"]}
            }
          ],
          "childrenSections": []
        }
      ]
    },
    {
      "id": "660e8400-e29b-41d4-a716-446655440500",
