                  {"key": "variable_name", "label": "Variable Name", "dataType": "string"},
                  {"key": "definition", "label": "Definition", "dataType": "string"},
                  {"key": "data_type", "label": "Type", "dataType": "string"},
                  {"key": "source", "label": "Source", "dataType": "string"},
                  {"key": "missing_treatment", "label": "Missing Treatment", "dataType": "string"},
                  {"key": "transformation", "label": "Transformation", "dataType": "string"}
