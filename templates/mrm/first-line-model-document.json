              "outputContract": {
                "schema": "LLM_TABLE",
                "tableColumns": [
                  {"key": "metric", "label": "Metric", "dataType": "string"},
                  {"key": "training", "label": "Training", "dataType": "number"},
                  {"key": "validation", "label": "Validation", "dataType": "number"},
                  {"key": "oot", "label": "Out-of-Time", "dataType": "number"}
                ]
              },
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
