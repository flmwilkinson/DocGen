            {
              "id": "660e8400-e29b-41d4-a716-446655440513",
              "type": "LLM_TABLE",
              "title": "Key Performance Metrics",
              "instructions": "Present key discrimination and rank-ordering metrics: Gini Coefficient, KS Statistic, AUC, Information Value, and Accuracy metrics. Show for training, validation, and out-of-time samples.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440514",
