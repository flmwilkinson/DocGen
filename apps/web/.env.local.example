# ============================================
# DocGen.AI - Local Development (No Docker)
# ============================================
# Copy to .env.local:  cp .env.local.example .env.local

# ============================================
# REQUIRED: OpenAI API
# ============================================
OPENAI_API_KEY="sk-your-key-here"

# Models
MODEL_FAST="gpt-4o-mini"
MODEL_DEFAULT="gpt-4o"
MODEL_EMBEDDING="text-embedding-3-small"

# ============================================
# OPTIONAL: Azure OpenAI / Custom Endpoint
# ============================================
# Uncomment for Azure OpenAI:
# OPENAI_BASE_URL="https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT"
# MODEL_FAST="your-azure-deployment-name"
# MODEL_DEFAULT="your-azure-deployment-name"

# ============================================
# REQUIRED: Database (Use FREE cloud - no install!)
# ============================================
# Option 1: Supabase (recommended) - https://supabase.com
# Option 2: Neon - https://neon.tech
# Both have free tiers, just sign up and copy connection string
DATABASE_URL="postgresql://user:password@host:5432/database"

# ============================================
# REQUIRED: GitHub OAuth
# ============================================
# Create at: https://github.com/settings/developers → New OAuth App
# - Homepage URL: http://localhost:3000
# - Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="your-client-id"
GITHUB_CLIENT_SECRET="your-client-secret"

# ============================================
# REQUIRED: Authentication
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-any-random-32-character-string"

# ============================================
# LOCAL MODE (No Docker)
# ============================================
STORAGE_TYPE="local"
PYTHON_EXECUTOR="local"
QUEUE_MODE="inline"

# ============================================
# OPTIONAL: Private GitHub repos
# ============================================
# GITHUB_TOKEN="ghp_your-personal-access-token"
