# ============================================
# DocGen.AI - Local Development Configuration
# ============================================
# Copy to .env.local:  cp .env.local.example .env.local
#
# This config runs WITHOUT Docker - just Node.js, Python, and PostgreSQL.

# ============================================
# REQUIRED: OpenAI API
# ============================================
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-key-here"

# Models (defaults work for standard OpenAI)
MODEL_FAST="gpt-4o-mini"
MODEL_DEFAULT="gpt-4o"
MODEL_EMBEDDING="text-embedding-3-small"

# For Azure OpenAI, uncomment and configure:
# OPENAI_BASE_URL="https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT"
# MODEL_FAST="your-azure-deployment-name"

# ============================================
# REQUIRED: GitHub OAuth
# ============================================
# Setup: https://github.com/settings/developers → New OAuth App
# - Homepage URL: http://localhost:3000
# - Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="your-client-id"
GITHUB_CLIENT_SECRET="your-client-secret"

# ============================================
# REQUIRED: Authentication
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ============================================
# REQUIRED: Database
# ============================================
# Install PostgreSQL locally or use a cloud provider
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/docgen"

# ============================================
# LOCAL MODE (No Docker Required)
# ============================================
# These settings enable running without Docker containers

# Storage: Use local filesystem instead of MinIO/S3
STORAGE_TYPE="local"
LOCAL_STORAGE_PATH="./data/storage"

# Python: Use local Python instead of Docker sandbox
PYTHON_EXECUTOR="local"
# Ensure Python 3.8+ with: pip install pandas numpy matplotlib seaborn

# Queue: Process jobs inline instead of Redis/BullMQ
QUEUE_MODE="inline"

# ============================================
# OPTIONAL: Docker Mode (for production)
# ============================================
# Uncomment these to use Docker services instead:

# STORAGE_TYPE="s3"
# S3_ENDPOINT="http://localhost:9000"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_BUCKET="docgen-artifacts"

# PYTHON_EXECUTOR="sandbox"
# SANDBOX_PYTHON_URL="http://localhost:8001"

# QUEUE_MODE="redis"
# REDIS_URL="redis://localhost:6379"

# ============================================
# OPTIONAL: Advanced Settings
# ============================================
NODE_ENV="development"
LOG_LEVEL="info"

# For private GitHub repos (optional)
# GITHUB_TOKEN="ghp_your-personal-access-token"
