# DocGen.AI - Local Environment Configuration
# Copy this file to .env.local and fill in your values
# For Docker-free local development

# ===========================================
# Database (SQLite - no Docker needed)
# ===========================================
DATABASE_URL="file:./docgen.db"

# ===========================================
# Storage (Local filesystem - no MinIO needed)
# ===========================================
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./storage

# ===========================================
# Queue System (Disabled - runs jobs inline)
# ===========================================
REDIS_ENABLED=false

# ===========================================
# Python Execution (Local - no Docker needed)
# ===========================================
NEXT_PUBLIC_USE_LOCAL_PYTHON=true
PYTHON_CMD=python
# If using virtual environment:
# PYTHON_CMD=.venv/Scripts/python

# ===========================================
# Repository Storage
# ===========================================
REPO_STORAGE_PATH=./repos

# ===========================================
# OpenAI / Azure OpenAI (REQUIRED)
# ===========================================
# Option 1: Direct OpenAI API
# OPENAI_API_KEY=sk-your-key-here

# Option 2: Azure OpenAI (recommended for enterprise)
OPENAI_API_KEY=your-azure-api-key
OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/gpt-4o
OPENAI_API_VERSION=2024-02-15-preview

# Model names (Azure deployment names or OpenAI model IDs)
MODEL_DEFAULT=gpt-4o
MODEL_FAST=gpt-4o-mini
MODEL_EMBEDDING=text-embedding-3-small

# ===========================================
# Authentication
# ===========================================
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=generate-a-32-char-secret-here
NEXTAUTH_URL=http://localhost:3000

# Auth mode: 'local' for email/password, 'github' for OAuth
AUTH_MODE=local

# GitHub OAuth (optional - only if AUTH_MODE=github)
# GITHUB_CLIENT_ID=your-github-oauth-app-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-secret

# GitHub Personal Access Token (for cloning private repos)
# GITHUB_TOKEN=ghp_your-personal-access-token

# ===========================================
# API Server
# ===========================================
API_PORT=4000
API_HOST=localhost

# ===========================================
# Frontend
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:4000

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
