  "sections": [
    {
      "id": "660e8400-e29b-41d4-a716-446655440010",
      "title": "Document Control",
      "level": 1,
      "description": "Document metadata and version control",
      "blocks": [
        {
          "id": "660e8400-e29b-41d4-a716-446655440011",
          "type": "USER_INPUT",
          "title": "Document Information",
          "userFields": [
            {
              "id": "660e8400-e29b-41d4-a716-446655440012",
              "name": "model_name",
              "label": "Model Name",
              "type": "TEXT",
              "required": true,
              "placeholder": "e.g., Probability of Default Model - SME Portfolio"
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440013",
              "name": "model_id",
              "label": "Model ID/Reference",
              "type": "TEXT",
              "required": true,
              "placeholder": "e.g., PD-SME-2024-001"
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440014",
              "name": "document_version",
              "label": "Document Version",
              "type": "TEXT",
              "required": true,
              "defaultValue": "1.0"
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440015",
              "name": "model_owner",
              "label": "Model Owner",
              "type": "TEXT",
              "required": true
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440016",
              "name": "model_developer",
              "label": "Model Developer(s)",
              "type": "TEXTAREA",
              "required": true
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440017",
              "name": "business_unit",
              "label": "Business Unit",
              "type": "TEXT",
              "required": true
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440018",
              "name": "model_tier",
              "label": "Model Risk Tier",
              "type": "SELECT",
              "required": true,
              "options": [
                {"value": "tier1", "label": "Tier 1 - Critical"},
                {"value": "tier2", "label": "Tier 2 - High"},
                {"value": "tier3", "label": "Tier 3 - Medium"},
                {"value": "tier4", "label": "Tier 4 - Low"}
              ]
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440019",
              "name": "effective_date",
              "label": "Effective Date",
              "type": "DATE",
              "required": true
            }
          ],
          "regenerationPolicy": {"allowed": false, "maxAttempts": 1, "cacheKeyStrategy": "none"},
          "citationPolicy": {"requireCitations": false, "allowedSources": []}
        },
        {
          "id": "660e8400-e29b-41d4-a716-446655440020",
          "type": "LLM_TABLE",
          "title": "Document Revision History",
          "instructions": "Create a revision history table documenting all changes to this model document. Include columns for Version, Date, Author, Description of Changes, and Approval Status.",
          "inputs": [],
          "outputContract": {
            "schema": "LLM_TABLE",
            "tableColumns": [
              {"key": "version", "label": "Version", "dataType": "string"},
              {"key": "date", "label": "Date", "dataType": "date"},
              {"key": "author", "label": "Author", "dataType": "string"},
              {"key": "changes", "label": "Description of Changes", "dataType": "string"},
              {"key": "approval", "label": "Approval Status", "dataType": "string"}
            ]
          },
          "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
          "citationPolicy": {"requireCitations": false, "allowedSources": []}
        }
      ],
      "childrenSections": []
    },
    {
      "id": "660e8400-e29b-41d4-a716-446655440100",
      "title": "Executive Summary",
      "level": 1,
      "description": "High-level overview of the model",
      "blocks": [
        {
          "id": "660e8400-e29b-41d4-a716-446655440101",
          "type": "LLM_TEXT",
          "title": "Model Overview",
          "instructions": "Provide a comprehensive executive summary of the model. Include: (1) Model purpose and business objectives, (2) Key features and capabilities, (3) Target population and use cases, (4) High-level methodology summary, (5) Key performance metrics, (6) Model limitations and known constraints. Keep this accessible to non-technical stakeholders.",
          "inputs": [
            {
              "id": "660e8400-e29b-41d4-a716-446655440102",
              "type": "ARTIFACT",
              "description": "Model development materials and specifications"
            }
          ],
          "outputContract": {"schema": "LLM_TEXT"},
          "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
          "citationPolicy": {"requireCitations": true, "allowedSources": ["artifact"]}
        },
        {
          "id": "660e8400-e29b-41d4-a716-446655440103",
          "type": "LLM_TABLE",
          "title": "Model Fact Sheet",
          "instructions": "Create a quick-reference fact sheet table with key model attributes: Model Type, Methodology, Key Inputs, Output, Performance Metrics (Gini, KS, etc.), Implementation Platform, and Refresh Frequency.",
          "inputs": [],
          "outputContract": {
            "schema": "LLM_TABLE",
            "tableColumns": [
              {"key": "attribute", "label": "Attribute", "dataType": "string"},
              {"key": "value", "label": "Value", "dataType": "string"}
            ]
          },
          "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
          "citationPolicy": {"requireCitations": false, "allowedSources": []}
        }
      ],
      "childrenSections": []
    },
    {
      "id": "660e8400-e29b-41d4-a716-446655440200",
      "title": "Business Context and Objectives",
      "level": 1,
      "description": "Business rationale and model objectives",
      "blocks": [
        {
          "id": "660e8400-e29b-41d4-a716-446655440201",
          "type": "LLM_TEXT",
          "title": "Business Problem Statement",
          "instructions": "Describe the business problem this model addresses. Include: (1) Current business challenges, (2) Decision-making context, (3) Stakeholders affected, (4) Cost of errors (both false positives and false negatives), (5) Regulatory drivers if applicable.",
          "inputs": [],
          "outputContract": {"schema": "LLM_TEXT"},
          "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
          "citationPolicy": {"requireCitations": false, "allowedSources": []}
        },
        {
          "id": "660e8400-e29b-41d4-a716-446655440202",
          "type": "LLM_TEXT",
          "title": "Model Use Cases",
          "instructions": "Detail the specific use cases for this model. For each use case describe: (1) The decision being supported, (2) How model output is used, (3) Decision thresholds or cutoffs, (4) Override policies, (5) Integration with other models or processes.",
          "inputs": [],
          "outputContract": {"schema": "LLM_TEXT"},
          "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
          "citationPolicy": {"requireCitations": false, "allowedSources": []}
        },
        {
          "id": "660e8400-e29b-41d4-a716-446655440203",
          "type": "USER_INPUT",
          "title": "Materiality Assessment",
          "userFields": [
            {
              "id": "660e8400-e29b-41d4-a716-446655440204",
              "name": "portfolio_size",
              "label": "Portfolio Size ($ or count)",
              "type": "TEXT",
              "required": true
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440205",
              "name": "annual_decisions",
              "label": "Annual Decisions Impacted",
              "type": "NUMBER",
              "required": true
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440206",
              "name": "regulatory_use",
              "label": "Regulatory Use",
              "type": "MULTISELECT",
              "required": true,
              "options": [
                {"value": "capital", "label": "Regulatory Capital"},
                {"value": "stress_testing", "label": "Stress Testing (CCAR/DFAST)"},
                {"value": "cecl", "label": "CECL/IFRS9 Provisioning"},
                {"value": "pricing", "label": "Risk-Based Pricing"},
                {"value": "none", "label": "No Direct Regulatory Use"}
              ]
            }
          ],
          "regenerationPolicy": {"allowed": false, "maxAttempts": 1, "cacheKeyStrategy": "none"},
          "citationPolicy": {"requireCitations": false, "allowedSources": []}
        }
      ],
      "childrenSections": []
    },
    {
      "id": "660e8400-e29b-41d4-a716-446655440300",
      "title": "Data Description",
      "level": 1,
      "description": "Comprehensive data documentation",
      "blocks": [],
      "childrenSections": [
        {
          "id": "660e8400-e29b-41d4-a716-446655440310",
          "title": "Data Sources",
          "level": 2,
          "blocks": [
            {
              "id": "660e8400-e29b-41d4-a716-446655440311",
              "type": "LLM_TABLE",
              "title": "Data Source Inventory",
              "instructions": "Document all data sources used in model development. Include: Source Name, System of Record, Data Owner, Refresh Frequency, Data Period Available, and Quality Rating.",
              "inputs": [],
              "outputContract": {
                "schema": "LLM_TABLE",
                "tableColumns": [
                  {"key": "source_name", "label": "Source Name", "dataType": "string"},
                  {"key": "system", "label": "System of Record", "dataType": "string"},
                  {"key": "owner", "label": "Data Owner", "dataType": "string"},
                  {"key": "frequency", "label": "Refresh Frequency", "dataType": "string"},
                  {"key": "period", "label": "Data Period", "dataType": "string"},
                  {"key": "quality", "label": "Quality Rating", "dataType": "string"}
                ]
              },
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": false, "allowedSources": []}
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440312",
              "type": "LLM_TEXT",
              "title": "Data Lineage and Transformations",
              "instructions": "Document the data lineage from source to model input. Describe key transformations, aggregations, and derivations applied. Include data flow diagrams if applicable.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440313",
                  "type": "REPO",
                  "query": "data transformation pipeline ETL",
                  "filters": {"filePatterns": ["*.py", "*.sql"]}
                }
              ],
              "outputContract": {"schema": "LLM_TEXT"},
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": true, "allowedSources": ["repo"]}
            }
          ],
          "childrenSections": []
        },
        {
          "id": "660e8400-e29b-41d4-a716-446655440320",
          "title": "Development Sample",
          "level": 2,
          "blocks": [
            {
              "id": "660e8400-e29b-41d4-a716-446655440321",
              "type": "USER_INPUT",
              "title": "Upload Development Data Summary",
              "userFields": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440322",
                  "name": "dev_data_summary",
                  "label": "Development Sample Statistics (CSV/Excel)",
                  "type": "FILE_UPLOAD",
                  "required": true,
                  "validation": {"allowedFileTypes": ["csv", "xlsx"]}
                }
              ],
              "regenerationPolicy": {"allowed": false, "maxAttempts": 1, "cacheKeyStrategy": "none"},
              "citationPolicy": {"requireCitations": false, "allowedSources": []}
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440323",
              "type": "LLM_TABLE",
              "title": "Sample Characteristics",
              "instructions": "Summarize development sample characteristics including: Total observations, Target event rate, Time period, Key segment distributions, and any exclusions applied with justification.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440324",
                  "type": "ARTIFACT",
                  "description": "Development data summary"
                }
              ],
              "outputContract": {
                "schema": "LLM_TABLE",
                "tableColumns": [
                  {"key": "characteristic", "label": "Characteristic", "dataType": "string"},
                  {"key": "value", "label": "Value", "dataType": "string"},
                  {"key": "notes", "label": "Notes", "dataType": "string"}
                ]
              },
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": true, "allowedSources": ["artifact"]}
            },
            {
              "id": "660e8400-e29b-41d4-a716-446655440325",
              "type": "LLM_CHART",
              "title": "Target Rate Over Time",
              "instructions": "Create a line chart showing the target event rate (e.g., default rate) over time across the development sample period. Include trend line and note any significant events or regime changes.",
              "inputs": [
                {
                  "id": "660e8400-e29b-41d4-a716-446655440326",
                  "type": "ARTIFACT",
                  "description": "Time series data"
                }
              ],
              "outputContract": {
                "schema": "LLM_CHART",
                "chartConfig": {
                  "preferredType": "line",
                  "xKey": "period",
                  "yKeys": ["event_rate"]
                }
              },
              "regenerationPolicy": {"allowed": true, "maxAttempts": 3, "cacheKeyStrategy": "inputs_hash"},
              "citationPolicy": {"requireCitations": true, "allowedSources": ["artifact"]}
            }
          ],
          "childrenSections": []
        },
        {
