// ===========================================
// DocGen.AI Database Schema
// ===========================================
// SQLite-compatible version for local development without Docker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===========================================
// User & Authentication
// ===========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  password  String? // Hashed password for credentials auth

  // Relations
  projects        Project[]
  templates       Template[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ===========================================
// Project
// ===========================================

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  repoUrl     String?
  settings    String   @default("{}") // JSON stored as string in SQLite

  // Relations
  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId        String
  repoSnapshots  RepoSnapshot[]
  artifacts      Artifact[]
  generationRuns GenerationRun[]
  templates      Template[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

// ===========================================
// Repository Snapshot
// ===========================================

// Note: SQLite doesn't support enums, so we use String with validation in code
// Valid values: PENDING, CLONING, INDEXING, BUILDING_KG, EMBEDDING, READY, FAILED

model RepoSnapshot {
  id           String  @id @default(uuid())
  commitHash   String?
  branch       String  @default("main")
  status       String  @default("PENDING") // RepoSnapshotStatus enum as string
  fileManifest String  @default("[]") // JSON array
  languageStats String @default("[]") // JSON array
  totalFiles   Int     @default(0)
  totalSize    Int     @default(0) // Changed from BigInt for SQLite compatibility
  localPath    String? // Path to cloned repo on disk
  errorMessage String?

  // Relations
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  knowledgeGraph KnowledgeGraph?
  vectorChunks   VectorChunk[]
  generationRuns GenerationRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("repo_snapshots")
}

// ===========================================
// Knowledge Graph
// ===========================================

model KnowledgeGraph {
  id      String @id @default(uuid())
  version Int    @default(1)
  nodes   String @default("[]") // JSON array
  edges   String @default("[]") // JSON array
  stats   String @default("{}") // JSON object

  // Relations
  repoSnapshot   RepoSnapshot @relation(fields: [repoSnapshotId], references: [id], onDelete: Cascade)
  repoSnapshotId String       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_graphs")
}

// ===========================================
// Artifact (Uploaded/Generated Files)
// ===========================================

// ArtifactType: UPLOADED_FILE, GENERATED_OUTPUT, EXPORT, REPO_ZIP

model Artifact {
  id               String  @id @default(uuid())
  type             String  // ArtifactType enum as string
  filename         String
  originalFilename String?
  mimeType         String
  size             Int     // Changed from BigInt for SQLite compatibility
  storageKey       String  // S3/MinIO key or local path
  metadata         String  @default("{}") // JSON object

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  vectorChunks VectorChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("artifacts")
}

// ===========================================
// Template
// ===========================================

model Template {
  id           String  @id @default(uuid())
  name         String
  description  String?
  templateJson String  // JSON - Validated TemplateSchema
  isPublic     Boolean @default(false)
  version      Int     @default(1)

  // Relations
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdById    String
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String?
  generationRuns GenerationRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("templates")
}

// ===========================================
// Generation Run
// ===========================================

// GenerationRunStatus: PENDING, RUNNING, PAUSED, COMPLETED, FAILED, CANCELLED

model GenerationRun {
  id             String  @id @default(uuid())
  status         String  @default("PENDING") // GenerationRunStatus enum as string
  inputs         String  @default("{}") // JSON - GenerationRunInputsSchema
  currentBlockId String?
  progress       Float   @default(0)
  errorMessage   String?

  // Relations
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  template         Template          @relation(fields: [templateId], references: [id])
  templateId       String
  repoSnapshot     RepoSnapshot?     @relation(fields: [repoSnapshotId], references: [id])
  repoSnapshotId   String?
  documentVersions DocumentVersion[]
  gapQuestions     GapQuestion[]
  agentTraces      AgentTrace[]

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("generation_runs")
}

// ===========================================
// Document Version
// ===========================================

model DocumentVersion {
  id              String @id @default(uuid())
  title           String
  contentJson     String @default("{}") // JSON - TipTap document
  version         Int    @default(1)
  exportArtifacts String @default("{}") // JSON object

  // Relations
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  generationRunId String
  blockOutputs    BlockOutput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("document_versions")
}

// ===========================================
// Block Output
// ===========================================

model BlockOutput {
  id          String  @id @default(uuid())
  blockId     String
  outputType  String
  content     String  @default("{}") // JSON object
  confidence  Float   @default(1)
  citations   String  @default("[]") // JSON array
  rawResponse String? // JSON - Debug: raw LLM response

  // Relations
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  documentVersionId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentVersionId, blockId])
  @@map("block_outputs")
}

// ===========================================
// Gap / Question
// ===========================================

// GapStatus: OPEN, ANSWERED, DISMISSED, AUTO_RESOLVED
// GapSeverity: low, medium, high, critical

model GapQuestion {
  id                 String   @id @default(uuid())
  blockId            String?
  question           String
  context            String?
  severity           String   // GapSeverity enum as string
  status             String   @default("OPEN") // GapStatus enum as string
  userAnswer         String?
  suggestedInputType String?
  choices            String?  // JSON array

  // Relations
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  generationRunId String

  answeredAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("gap_questions")
}

// ===========================================
// Vector Chunk (for semantic search)
// ===========================================

model VectorChunk {
  id           String  @id @default(uuid())
  sourceType   String  // 'repo_file' | 'artifact'
  sourcePath   String
  chunkIndex   Int
  content      String
  startLine    Int?
  endLine      Int?
  metadata     String  @default("{}") // JSON object
  embedding    String? // JSON array of floats for vector search (was pgvector)

  // Relations
  repoSnapshot   RepoSnapshot? @relation(fields: [repoSnapshotId], references: [id], onDelete: Cascade)
  repoSnapshotId String?
  artifact       Artifact?     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  artifactId     String?

  createdAt DateTime @default(now())

  @@index([repoSnapshotId])
  @@index([artifactId])
  @@map("vector_chunks")
}

// ===========================================
// Agent Trace (for debugging/observability)
// ===========================================

model AgentTrace {
  id              String @id @default(uuid())
  blockId         String?
  events          String @default("[]") // JSON array
  totalTokens     Int    @default(0)
  totalDurationMs Int    @default(0)
  status          String @default("running")
  error           String?

  // Relations
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  generationRunId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agent_traces")
}
