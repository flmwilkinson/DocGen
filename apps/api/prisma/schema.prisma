// ===========================================
// DocGen.AI Database Schema
// ===========================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ===========================================
// User & Authentication
// ===========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  password  String? // Hashed password for credentials auth
  
  // Relations
  projects        Project[]
  templates       Template[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("users")
}

// ===========================================
// Project
// ===========================================

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  repoUrl     String?
  settings    Json     @default("{}")
  
  // Relations
  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId        String
  repoSnapshots  RepoSnapshot[]
  artifacts      Artifact[]
  generationRuns GenerationRun[]
  templates      Template[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("projects")
}

// ===========================================
// Repository Snapshot
// ===========================================

enum RepoSnapshotStatus {
  PENDING
  CLONING
  INDEXING
  BUILDING_KG
  EMBEDDING
  READY
  FAILED
}

model RepoSnapshot {
  id           String             @id @default(uuid())
  commitHash   String?
  branch       String             @default("main")
  status       RepoSnapshotStatus @default(PENDING)
  fileManifest Json               @default("[]")
  languageStats Json              @default("[]")
  totalFiles   Int                @default(0)
  totalSize    BigInt             @default(0)
  localPath    String? // Path to cloned repo on disk
  errorMessage String?
  
  // Relations
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  knowledgeGraph KnowledgeGraph?
  vectorChunks   VectorChunk[]
  generationRuns GenerationRun[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("repo_snapshots")
}

// ===========================================
// Knowledge Graph
// ===========================================

model KnowledgeGraph {
  id      String @id @default(uuid())
  version Int    @default(1)
  nodes   Json   @default("[]")
  edges   Json   @default("[]")
  stats   Json   @default("{}")
  
  // Relations
  repoSnapshot   RepoSnapshot @relation(fields: [repoSnapshotId], references: [id], onDelete: Cascade)
  repoSnapshotId String       @unique
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("knowledge_graphs")
}

// ===========================================
// Artifact (Uploaded/Generated Files)
// ===========================================

enum ArtifactType {
  UPLOADED_FILE
  GENERATED_OUTPUT
  EXPORT
  REPO_ZIP
}

model Artifact {
  id               String       @id @default(uuid())
  type             ArtifactType
  filename         String
  originalFilename String?
  mimeType         String
  size             BigInt
  storageKey       String // S3/MinIO key
  metadata         Json         @default("{}")
  
  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  vectorChunks VectorChunk[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("artifacts")
}

// ===========================================
// Template
// ===========================================

model Template {
  id           String  @id @default(uuid())
  name         String
  description  String?
  templateJson Json // Validated TemplateSchema
  isPublic     Boolean @default(false)
  version      Int     @default(1)
  
  // Relations
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdById    String
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String?
  generationRuns GenerationRun[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("templates")
}

// ===========================================
// Generation Run
// ===========================================

enum GenerationRunStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model GenerationRun {
  id             String              @id @default(uuid())
  status         GenerationRunStatus @default(PENDING)
  inputs         Json                @default("{}") // GenerationRunInputsSchema
  currentBlockId String?
  progress       Float               @default(0)
  errorMessage   String?
  
  // Relations
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  template         Template          @relation(fields: [templateId], references: [id])
  templateId       String
  repoSnapshot     RepoSnapshot?     @relation(fields: [repoSnapshotId], references: [id])
  repoSnapshotId   String?
  documentVersions DocumentVersion[]
  gapQuestions     GapQuestion[]
  agentTraces      AgentTrace[]
  
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  @@map("generation_runs")
}

// ===========================================
// Document Version
// ===========================================

model DocumentVersion {
  id             String @id @default(uuid())
  title          String
  contentJson    Json   @default("{}") // TipTap JSON
  version        Int    @default(1)
  exportArtifacts Json  @default("{}")
  
  // Relations
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  generationRunId String
  blockOutputs    BlockOutput[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("document_versions")
}

// ===========================================
// Block Output
// ===========================================

model BlockOutput {
  id          String @id @default(uuid())
  blockId     String
  outputType  String
  content     Json   @default("{}")
  confidence  Float  @default(1)
  citations   Json   @default("[]")
  rawResponse Json? // Debug: raw LLM response
  
  // Relations
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  documentVersionId String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([documentVersionId, blockId])
  @@map("block_outputs")
}

// ===========================================
// Gap / Question
// ===========================================

enum GapStatus {
  OPEN
  ANSWERED
  DISMISSED
  AUTO_RESOLVED
}

enum GapSeverity {
  low
  medium
  high
  critical
}

model GapQuestion {
  id                 String      @id @default(uuid())
  blockId            String?
  question           String
  context            String?
  severity           GapSeverity
  status             GapStatus   @default(OPEN)
  userAnswer         String?
  suggestedInputType String?
  choices            Json?
  
  // Relations
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  generationRunId String
  
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  @@map("gap_questions")
}

// ===========================================
// Vector Chunk (for semantic search)
// ===========================================

model VectorChunk {
  id           String  @id @default(uuid())
  sourceType   String // 'repo_file' | 'artifact'
  sourcePath   String
  chunkIndex   Int
  content      String
  startLine    Int?
  endLine      Int?
  metadata     Json    @default("{}")
  embedding    Unsupported("vector(1536)")?
  
  // Relations
  repoSnapshot   RepoSnapshot? @relation(fields: [repoSnapshotId], references: [id], onDelete: Cascade)
  repoSnapshotId String?
  artifact       Artifact?     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  artifactId     String?
  
  createdAt DateTime @default(now())
  
  @@index([repoSnapshotId])
  @@index([artifactId])
  @@map("vector_chunks")
}

// ===========================================
// Agent Trace (for debugging/observability)
// ===========================================

model AgentTrace {
  id              String @id @default(uuid())
  blockId         String?
  events          Json   @default("[]")
  totalTokens     Int    @default(0)
  totalDurationMs Int    @default(0)
  status          String @default("running")
  error           String?
  
  // Relations
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  generationRunId String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("agent_traces")
}

